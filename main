import { useEffect, useMemo, useRef, useState } from "react";
import {
  AlertTriangle,
  BookOpen,
  Check,
  Copy,
  Database,
  Download,
  Edit3,
  Eye,
  FileText,
  Globe,
  Link as LinkIcon,
  Link2,
  Mic,
  Plus,
  RotateCcw,
  Save,
  Search,
  Shield,
  Trash2,
  Upload,
  User,
  X,
} from "lucide-react";

declare global {
  interface Window {
    storage?: {
      get: (key: string) => Promise<{ value?: string } | null>;
      set: (key: string, value: string) => Promise<void>;
    };
  }
}

type Rating = "sfw" | "nsfw";
type FilterMode = "all" | Rating;
type TabKey = "worlds" | "characters" | "voice" | "storylines";
type SaveState = "idle" | "saving" | "saved" | "error";

type BaseRecord = {
  id: string;
  name: string;
  rating: Rating;
  flags: string[];
  createdAt: string;
  updatedAt: string;
};

type WorldRecord = BaseRecord & {
  cosmology: string;
  factions: string;
  locations: string;
  rules: string;
  tone: string;
  mechanics: string;
  antagonistLogic: string;
  aiDirectorPrompt: string;
  voiceConventions: string;
};

type CharacterRecord = BaseRecord & {
  worldId: string;
  role: string;
  appearance: string;
  personality: string;
  backstory: string;
  speech: string;
  goals: string;
};

type VoiceRecord = BaseRecord & {
  characterId: string;
  register: string;
  cadence: string;
  lexicon: string;
  samplePrompt: string;
  refAudio: string;
};

type StorylineRecord = BaseRecord & {
  worldId: string;
  characterIds: string[];
  premise: string;
  openingScene: string;
  beats: string;
  branchingRules: string;
  continuityState: string;
  endingConditions: string;
};

type PlatformLink = {
  id: string;
  name: string;
  tos: string;
  promos: string;
  readme: string;
  notes: string;
};

type AnyRecord = WorldRecord | CharacterRecord | VoiceRecord | StorylineRecord;

type DeletedRecord = {
  tombstoneId: string;
  collection: TabKey;
  record: AnyRecord;
  deletedAt: string;
};

type ForgeState = {
  forgeVersion: number;
  worlds: WorldRecord[];
  chars: CharacterRecord[];
  voices: VoiceRecord[];
  storylines: StorylineRecord[];
  platforms: PlatformLink[];
  deleted: DeletedRecord[];
  mode: FilterMode;
  deployProfile: string;
};

type DeployBlock = [key: string, label: string, value: string];

const STORAGE_KEY = "forge:state:v10";
const LEGACY_STORAGE_KEY = "forge:state:v6";
const FIVE_MB = 5 * 1024 * 1024;

const FLAGS = ["violence", "explicit sexual", "drug use", "self-harm", "graphic language", "dark themes"];

const TABS: Array<{ key: TabKey; label: string; singular: string; icon: typeof Globe }> = [
  { key: "worlds", label: "Worlds", singular: "world", icon: Globe },
  { key: "characters", label: "Characters", singular: "character", icon: User },
  { key: "voice", label: "Voices", singular: "voice", icon: Mic },
  { key: "storylines", label: "Storylines", singular: "storyline", icon: FileText },
];

const FIELDS: Record<TabKey, Array<[keyof AnyRecord & string, string]>> = {
  worlds: [
    ["cosmology", "Cosmology / Metaphysics"],
    ["factions", "Factions"],
    ["locations", "Locations"],
    ["rules", "Rules / Logic"],
    ["tone", "Tone"],
    ["mechanics", "Mechanics / Resource Systems"],
    ["antagonistLogic", "Antagonist Logic"],
    ["aiDirectorPrompt", "AI Director System Prompt"],
    ["voiceConventions", "Voice & POV Conventions"],
  ],
  characters: [
    ["role", "Role / Archetype"],
    ["appearance", "Appearance"],
    ["personality", "Personality"],
    ["backstory", "Backstory"],
    ["speech", "Speech Patterns"],
    ["goals", "Goals / Drives"],
  ],
  voice: [
    ["register", "Register"],
    ["cadence", "Cadence / Rhythm"],
    ["lexicon", "Lexicon / Signature Terms"],
    ["samplePrompt", "Sample Generation Prompt"],
    ["refAudio", "Reference Audio URL"],
  ],
  storylines: [
    ["premise", "Premise"],
    ["openingScene", "Opening Scene"],
    ["beats", "Major Beats"],
    ["branchingRules", "Branching / Choice Rules"],
    ["continuityState", "Current Continuity State"],
    ["endingConditions", "Ending Conditions"],
  ],
};

const TIPS = [
  { h: "Signal Chain First", b: "Soft room. Mic 4-6in off-axis. Pop filter. Peaks -12 to -6 dB, never red." },
  { h: "One-Time Setup", b: "48000 Hz, 32-bit float. Software Playthrough OFF. Show Clipping ON. Meter range -60 dB." },
  { h: "Novice Loop", b: "Record 10s silence first for room tone. Clap-restart flubs. Normalize to -3 dB after light cleanup." },
  { h: "Adept Session", b: "Track 1: pristine room tone. Track 2: slate. Tracks 3+: takes on separate tracks. Keep 2s pre/post-roll." },
  { h: "Effect Chain", b: "1) HPF 80Hz 2) Noise Reduction 3) Gentle EQ 4) Compressor 5) Limiter -1dB 6) Normalize -3dB." },
  { h: "Failure Modes", b: "Sibilance, plosives, boxy rooms, thin over-EQ, and mouth noise. Fix the source before stacking effects." },
  { h: "Range Blocks", b: "Neutral, restrained intensity, sardonic, clinical, collapse. Label takes by register." },
];

const DEPLOY_PROFILES = [
  { key: "isekai-zero", name: "Isekai Zero", note: "Six copy blocks shaped for Isekai Zero character creation and Advanced Mode." },
  { key: "character-ai", name: "Character.AI", note: "Condensed persona, greeting, definition, and example dialogue blocks." },
  { key: "sillytavern", name: "SillyTavern", note: "Persona-card style blocks: description, personality, scenario, first message, examples." },
  { key: "generic", name: "Generic Bot", note: "Platform-agnostic system/context bundle for any stateless bot session." },
];

const nowIso = () => new Date().toISOString();
const uid = () => (typeof crypto !== "undefined" && crypto.randomUUID ? crypto.randomUUID() : `id-${Date.now()}-${Math.random().toString(16).slice(2)}`);
const slug = (s: string) => s.toLowerCase().trim().replace(/[^a-z0-9]+/g, "-").replace(/(^-|-$)/g, "");
const stripMd = (s: string) => s.replace(/[#*_`>~[\]()]/g, "").replace(/\s+/g, " ").trim();
const wordCount = (s: string) => s.trim().split(/\s+/).filter(Boolean).length;
const compactWords = (s: string, max = 30) => stripMd(s).split(/\s+/).filter(Boolean).slice(0, max).join(" ");

const baseRecord = (name: string): BaseRecord => ({
  id: uid(),
  name,
  rating: "sfw",
  flags: [],
  createdAt: nowIso(),
  updatedAt: nowIso(),
});

const emptyWorld = (): WorldRecord => ({
  ...baseRecord("Untitled World"),
  cosmology: "",
  factions: "",
  locations: "",
  rules: "",
  tone: "",
  mechanics: "",
  antagonistLogic: "",
  aiDirectorPrompt: "",
  voiceConventions: "",
});

const emptyChar = (): CharacterRecord => ({
  ...baseRecord("Untitled Character"),
  worldId: "",
  role: "",
  appearance: "",
  personality: "",
  backstory: "",
  speech: "",
  goals: "",
});

const emptyVoice = (): VoiceRecord => ({
  ...baseRecord("Untitled Voice"),
  characterId: "",
  register: "",
  cadence: "",
  lexicon: "",
  samplePrompt: "",
  refAudio: "",
});

const emptyStoryline = (): StorylineRecord => ({
  ...baseRecord("Untitled Storyline"),
  worldId: "",
  characterIds: [],
  premise: "",
  openingScene: "",
  beats: "",
  branchingRules: "",
  continuityState: "",
  endingConditions: "",
});

const defaultPlatforms = (): PlatformLink[] => [
  { id: uid(), name: "Isekai Zero", tos: "", promos: "", readme: "", notes: "" },
  { id: uid(), name: "Character.AI", tos: "", promos: "", readme: "", notes: "" },
  { id: uid(), name: "SillyTavern", tos: "", promos: "", readme: "", notes: "" },
];

const storageRead = async (key: string) => {
  if (typeof window === "undefined") return null;
  if (window.storage?.get) {
    const result = await window.storage.get(key);
    return result?.value || null;
  }
  return window.localStorage.getItem(key);
};

const storageWrite = async (key: string, value: string) => {
  if (typeof window === "undefined") return;
  if (window.storage?.set) {
    await window.storage.set(key, value);
    return;
  }
  window.localStorage.setItem(key, value);
};

const estimateBytes = (payload: string) => {
  try {
    return new Blob([payload]).size;
  } catch {
    return payload.length;
  }
};

const normalizeRecord = <T extends AnyRecord>(record: Partial<T>, fallback: T): T => ({
  ...fallback,
  ...record,
  rating: record.rating === "nsfw" ? "nsfw" : "sfw",
  flags: Array.isArray(record.flags) ? record.flags : [],
  createdAt: record.createdAt || nowIso(),
  updatedAt: record.updatedAt || nowIso(),
});

const normalizeWorld = (record: Partial<WorldRecord>) => normalizeRecord(record, emptyWorld());
const normalizeChar = (record: Partial<CharacterRecord>) => normalizeRecord(record, emptyChar());
const normalizeVoice = (record: Partial<VoiceRecord>) => normalizeRecord(record, emptyVoice());
const normalizeStoryline = (record: Partial<StorylineRecord>) => normalizeRecord(record, emptyStoryline());

const normalizePlatform = (platform: Partial<PlatformLink>): PlatformLink => ({
  id: platform.id || uid(),
  name: platform.name || "New Platform",
  tos: platform.tos || "",
  promos: platform.promos || "",
  readme: platform.readme || "",
  notes: platform.notes || "",
});

const summarizeCharacter = (character: CharacterRecord) => {
  const direct = [character.role, character.personality].filter(Boolean).join(" ");
  const firstSentence = stripMd(direct).split(/(?<=[.!?])\s+/)[0] || direct;
  return compactWords(firstSentence || `${character.name} is a character awaiting definition.`, 30);
};

export default function Forge() {
  const [tab, setTab] = useState<TabKey>("worlds");
  const [worlds, setWorlds] = useState<WorldRecord[]>([]);
  const [chars, setChars] = useState<CharacterRecord[]>([]);
  const [voices, setVoices] = useState<VoiceRecord[]>([]);
  const [storylines, setStorylines] = useState<StorylineRecord[]>([]);
  const [platforms, setPlatforms] = useState<PlatformLink[]>(defaultPlatforms);
  const [deleted, setDeleted] = useState<DeletedRecord[]>([]);
  const [sel, setSel] = useState<Record<TabKey, string | null>>({ worlds: null, characters: null, voice: null, storylines: null });
  const [mode, setMode] = useState<FilterMode>("all");
  const [query, setQuery] = useState("");
  const [deployProfile, setDeployProfile] = useState("isekai-zero");
  const [deployView, setDeployView] = useState(false);
  const [showTips, setShowTips] = useState(false);
  const [showPlatforms, setShowPlatforms] = useState(false);
  const [showParse, setShowParse] = useState(false);
  const [showTrash, setShowTrash] = useState(false);
  const [parseInput, setParseInput] = useState("");
  const [parseOutput, setParseOutput] = useState("");
  const [parseMsg, setParseMsg] = useState("");
  const [parseDraft, setParseDraft] = useState<Record<string, string> | null>(null);
  const [parseSelected, setParseSelected] = useState<Record<string, boolean>>({});
  const [parseApplyMode, setParseApplyMode] = useState<"append" | "replace">("append");
  const [copied, setCopied] = useState<string | null>(null);
  const [loaded, setLoaded] = useState(false);
  const [saveState, setSaveState] = useState<SaveState>("idle");
  const [lastSaved, setLastSaved] = useState("");
  const [storageBytes, setStorageBytes] = useState(0);
  const importRef = useRef<HTMLInputElement | null>(null);

  const collections: Record<TabKey, AnyRecord[]> = useMemo(
    () => ({ worlds, characters: chars, voice: voices, storylines }),
    [worlds, chars, voices, storylines],
  );

  const statePayload: ForgeState = useMemo(
    () => ({ forgeVersion: 10, worlds, chars, voices, storylines, platforms, deleted, mode, deployProfile }),
    [worlds, chars, voices, storylines, platforms, deleted, mode, deployProfile],
  );

  useEffect(() => {
    (async () => {
      try {
        const raw = (await storageRead(STORAGE_KEY)) || (await storageRead(LEGACY_STORAGE_KEY));
        if (raw) {
          const state = JSON.parse(raw);
          setWorlds((state.worlds || []).map(normalizeWorld));
          setChars((state.chars || []).map(normalizeChar));
          setVoices((state.voices || []).map(normalizeVoice));
          setStorylines((state.storylines || []).map(normalizeStoryline));
          setPlatforms((state.platforms?.length ? state.platforms : defaultPlatforms()).map(normalizePlatform));
          setDeleted(state.deleted || []);
          setMode(state.mode || "all");
          setDeployProfile(state.deployProfile || "isekai-zero");
        }
      } catch (error) {
        console.warn("Forge load failed", error);
      }
      setLoaded(true);
    })();
  }, []);

  useEffect(() => {
    if (!loaded) return;
    const payload = JSON.stringify(statePayload);
    setStorageBytes(estimateBytes(payload));
    setSaveState("saving");
    const timer = window.setTimeout(async () => {
      try {
        await storageWrite(STORAGE_KEY, payload);
        setSaveState("saved");
        setLastSaved(new Date().toLocaleTimeString());
      } catch (error) {
        console.warn("Forge save failed", error);
        setSaveState("error");
      }
    }, 300);
    return () => window.clearTimeout(timer);
  }, [statePayload, loaded]);

  const items = collections[tab];
  const tabMeta = TABS.find((t) => t.key === tab)!;
  const current = (items.find((item) => item.id === sel[tab]) || null) as AnyRecord | null;
  const linkedWorld = current && (tab === "characters" || tab === "storylines") ? worlds.find((w) => w.id === (current as CharacterRecord | StorylineRecord).worldId) || null : null;
  const linkedChar = current && tab === "voice" ? chars.find((c) => c.id === (current as VoiceRecord).characterId) || null : null;
  const linkedVoice = current && tab === "characters" ? voices.find((v) => v.characterId === current.id) || null : null;
  const linkedStoryCharacters = current && tab === "storylines" ? chars.filter((c) => (current as StorylineRecord).characterIds.includes(c.id)) : [];
  const worldCharacters = current && tab === "worlds" ? chars.filter((c) => c.worldId === current.id) : [];
  const worldStorylines = current && tab === "worlds" ? storylines.filter((s) => s.worldId === current.id) : [];

  const visible = useMemo(() => {
    const q = query.trim().toLowerCase();
    return items
      .filter((item) => mode === "all" || item.rating === mode)
      .filter((item) => {
        if (!q) return true;
        const haystack = [item.name, ...FIELDS[tab].map(([key]) => String((item as Record<string, unknown>)[key] || ""))].join("\n").toLowerCase();
        return haystack.includes(q);
      })
      .sort((a, b) => a.name.localeCompare(b.name));
  }, [items, mode, query, tab]);

  const setItemsFor = (key: TabKey, updater: (records: AnyRecord[]) => AnyRecord[]) => {
    const stamp = (records: AnyRecord[]) => updater(records).map((record) => ({ ...record, updatedAt: record.updatedAt || nowIso() }));
    if (key === "worlds") setWorlds((prev) => stamp(prev) as WorldRecord[]);
    if (key === "characters") setChars((prev) => stamp(prev) as CharacterRecord[]);
    if (key === "voice") setVoices((prev) => stamp(prev) as VoiceRecord[]);
    if (key === "storylines") setStorylines((prev) => stamp(prev) as StorylineRecord[]);
  };

  const add = () => {
    const factory: Record<TabKey, () => AnyRecord> = { worlds: emptyWorld, characters: emptyChar, voice: emptyVoice, storylines: emptyStoryline };
    const next = factory[tab]();
    setItemsFor(tab, (prev) => [...prev, next]);
    setSel({ ...sel, [tab]: next.id });
    setDeployView(false);
  };

  const update = (key: string, value: unknown) => {
    if (!current) return;
    setItemsFor(tab, (prev) => prev.map((item) => (item.id === current.id ? { ...item, [key]: value, updatedAt: nowIso() } : item)));
  };

  const softDelete = (id: string) => {
    const record = items.find((item) => item.id === id);
    if (!record) return;
    setDeleted((prev) => [{ tombstoneId: uid(), collection: tab, record, deletedAt: nowIso() }, ...prev]);
    setItemsFor(tab, (prev) => prev.filter((item) => item.id !== id));
    if (sel[tab] === id) setSel({ ...sel, [tab]: null });
  };

  const restoreDeleted = (tombstoneId: string) => {
    const tombstone = deleted.find((entry) => entry.tombstoneId === tombstoneId);
    if (!tombstone) return;
    setItemsFor(tombstone.collection, (prev) => [{ ...tombstone.record, updatedAt: nowIso() }, ...prev.filter((record) => record.id !== tombstone.record.id)]);
    setDeleted((prev) => prev.filter((entry) => entry.tombstoneId !== tombstoneId));
  };

  const purgeDeleted = (tombstoneId: string) => setDeleted((prev) => prev.filter((entry) => entry.tombstoneId !== tombstoneId));

  const toggleFlag = (flag: string) => {
    if (!current) return;
    const flags = current.flags.includes(flag) ? current.flags.filter((item) => item !== flag) : [...current.flags, flag];
    update("flags", flags);
  };

  const copy = async (text: string, id: string) => {
    try {
      await navigator.clipboard.writeText(text);
      setCopied(id);
      window.setTimeout(() => setCopied(null), 1200);
    } catch {
      setCopied(null);
    }
  };

  const download = (name: string, content: string, type = "text/plain") => {
    const blob = new Blob([content], { type });
    const anchor = document.createElement("a");
    const url = URL.createObjectURL(blob);
    anchor.href = url;
    anchor.download = name.replace(/[^\w.-]+/g, "_");
    anchor.click();
    URL.revokeObjectURL(url);
  };

  const exportBundle = () => download(`forge-backup-${new Date().toISOString().slice(0, 10)}.json`, JSON.stringify(statePayload, null, 2), "application/json");

  const mergeById = <T extends { id: string }>(base: T[], incoming: T[]) => {
    const map = new Map(base.map((record) => [record.id, record]));
    incoming.forEach((record) => map.set(record.id || uid(), { ...record, id: record.id || uid() }));
    return Array.from(map.values());
  };

  const handleImport = async (file?: File) => {
    if (!file) return;
    try {
      const text = await file.text();
      const parsed = JSON.parse(text);
      const isBundle = parsed.worlds || parsed.chars || parsed.voices || parsed.storylines;
      if (isBundle) {
        const replace = window.confirm("Replace current Forge state? Choose Cancel to merge imported records instead.");
        const nextWorlds = (parsed.worlds || []).map(normalizeWorld);
        const nextChars = (parsed.chars || []).map(normalizeChar);
        const nextVoices = (parsed.voices || []).map(normalizeVoice);
        const nextStorylines = (parsed.storylines || []).map(normalizeStoryline);
        if (replace) {
          setWorlds(nextWorlds);
          setChars(nextChars);
          setVoices(nextVoices);
          setStorylines(nextStorylines);
          setPlatforms((parsed.platforms || []).map(normalizePlatform));
          setDeleted(parsed.deleted || []);
        } else {
          setWorlds((prev) => mergeById(prev, nextWorlds));
          setChars((prev) => mergeById(prev, nextChars));
          setVoices((prev) => mergeById(prev, nextVoices));
          setStorylines((prev) => mergeById(prev, nextStorylines));
          setPlatforms((prev) => mergeById(prev, (parsed.platforms || []).map(normalizePlatform)));
        }
      } else if (parsed.id && parsed.name) {
        const normalized = normalizeByTab(tab, parsed);
        setItemsFor(tab, (prev) => [{ ...normalized, id: prev.some((record) => record.id === normalized.id) ? uid() : normalized.id }, ...prev]);
      }
    } catch (error) {
      alert(`Import failed: ${error instanceof Error ? error.message : "unknown error"}`);
    } finally {
      if (importRef.current) importRef.current.value = "";
    }
  };

  const normalizeByTab = (key: TabKey, record: Partial<AnyRecord>): AnyRecord => {
    if (key === "worlds") return normalizeWorld(record as Partial<WorldRecord>);
    if (key === "characters") return normalizeChar(record as Partial<CharacterRecord>);
    if (key === "voice") return normalizeVoice(record as Partial<VoiceRecord>);
    return normalizeStoryline(record as Partial<StorylineRecord>);
  };

  const exportMD = () => {
    if (!current) return;
    let markdown = `# ${current.name}\n\n**Type:** ${tabMeta.singular}\n**Rating:** ${current.rating}\n`;
    if (current.flags.length) markdown += `**Flags:** ${current.flags.join(", ")}\n`;
    markdown += `**Updated:** ${current.updatedAt}\n\n`;
    FIELDS[tab].forEach(([key, label]) => {
      const value = String((current as Record<string, unknown>)[key] || "");
      if (value) markdown += `## ${label}\n${value}\n\n`;
    });
    if (linkedWorld) markdown += `## Linked World: ${linkedWorld.name}\n${linkedWorld.cosmology || ""}\n\n${linkedWorld.rules ? `### Rules\n${linkedWorld.rules}\n\n` : ""}`;
    if (linkedChar) markdown += `## Linked Character: ${linkedChar.name}\n${linkedChar.personality || linkedChar.speech || ""}\n\n`;
    if (linkedStoryCharacters.length) markdown += `## Linked Characters\n${linkedStoryCharacters.map((c) => `- ${c.name}: ${compactWords(c.role || c.personality, 24)}`).join("\n")}\n\n`;
    download(`${current.name}.md`, markdown, "text/markdown");
  };

  const exportJSON = () => {
    if (!current) return;
    download(`${current.name}.json`, JSON.stringify({ ...current, linkedWorld, linkedChar, linkedVoice, linkedStoryCharacters }, null, 2), "application/json");
  };

  const exportDirectorPrompt = () => {
    if (!current || tab !== "worlds") return;
    const world = current as WorldRecord;
    const blocks = [
      `# ${world.name} - AI Director Brief\n`,
      world.voiceConventions && `## Voice & POV Conventions\n${world.voiceConventions}\n`,
      world.tone && `## Tone\n${world.tone}\n`,
      world.cosmology && `## Cosmology\n${world.cosmology}\n`,
      world.rules && `## World Rules\n${world.rules}\n`,
      world.mechanics && `## Mechanics & Resource Systems\n${world.mechanics}\n`,
      world.antagonistLogic && `## Antagonist Logic\n${world.antagonistLogic}\n`,
      world.factions && `## Factions\n${world.factions}\n`,
      world.locations && `## Locations\n${world.locations}\n`,
      world.aiDirectorPrompt && `## Director Instructions\n${world.aiDirectorPrompt}\n`,
      "---\nUse this as a persistent system/developer-style brief when spinning up a new bot session.",
    ].filter(Boolean);
    download(`${world.name}-director-prompt.md`, blocks.join("\n"), "text/markdown");
  };

  const exportSessionBrief = () => {
    if (!current) return;
    const character = tab === "characters" ? (current as CharacterRecord) : tab === "voice" && linkedChar ? linkedChar : null;
    const world = linkedWorld || (character ? worlds.find((w) => w.id === character.worldId) : tab === "worlds" ? (current as WorldRecord) : null);
    const story = tab === "storylines" ? (current as StorylineRecord) : null;
    const voice = character ? voices.find((v) => v.characterId === character.id) : linkedVoice;
    const markdown = [
      "# Session Continuity Brief",
      world && `## World: ${world.name}\n${world.cosmology}\n\n### Rules\n${world.rules}\n\n### Tone\n${world.tone}\n\n### Director Instructions\n${world.aiDirectorPrompt}`,
      character && `## Active Character: ${character.name}\n### Role\n${character.role}\n\n### Personality\n${character.personality}\n\n### Backstory\n${character.backstory}\n\n### Goals\n${character.goals}\n\n### Speech\n${character.speech}`,
      voice && `## Voice Layer: ${voice.name}\n### Register\n${voice.register}\n\n### Cadence\n${voice.cadence}\n\n### Lexicon\n${voice.lexicon}`,
      story && `## Storyline: ${story.name}\n### Premise\n${story.premise}\n\n### Current State\n${story.continuityState}\n\n### Branching Rules\n${story.branchingRules}`,
      "## Continuity Instruction\nMaintain the above world logic, character behavior, voice conventions, and current narrative state. If a future user message conflicts with this brief, preserve the brief unless the user explicitly revises canon.",
    ].filter(Boolean).join("\n\n");
    download(`session-brief-${current.name}.md`, markdown, "text/markdown");
  };

  const buildFullDescription = (character: CharacterRecord) => [
    character.role && `Role: ${character.role}`,
    character.appearance && `Appearance: ${character.appearance}`,
    character.personality && `Personality: ${character.personality}`,
    character.backstory && `Backstory: ${character.backstory}`,
    character.goals && `Goals: ${character.goals}`,
    character.speech && `Speech Style: ${character.speech}`,
  ].filter(Boolean).join("\n\n");

  const buildWorldContext = (world?: WorldRecord | null) => world ? [
    world.voiceConventions && `## Voice & POV Conventions\n${world.voiceConventions}`,
    world.tone && `## Tone\n${world.tone}`,
    world.cosmology && `## World Context\n${world.cosmology}`,
    world.rules && `## World Rules\n${world.rules}`,
    world.mechanics && `## Mechanics\n${world.mechanics}`,
    world.antagonistLogic && `## Antagonist Logic\n${world.antagonistLogic}`,
    world.factions && `## Factions\n${world.factions}`,
    world.locations && `## Locations\n${world.locations}`,
    world.aiDirectorPrompt && `## Director Instructions\n${world.aiDirectorPrompt}`,
  ].filter(Boolean).join("\n\n") : "";

  const buildCharacterDeploy = (profile: string, character: CharacterRecord): DeployBlock[] => {
    const world = worlds.find((item) => item.id === character.worldId) || null;
    const voice = voices.find((item) => item.characterId === character.id) || null;
    const fullDescription = buildFullDescription(character);
    const worldContext = buildWorldContext(world);
    const tags = [character.rating, ...character.flags, world?.name ? slug(world.name) : ""].filter(Boolean).join(", ");
    const promptDescription = [
      worldContext,
      `## Character: ${character.name}\n${fullDescription}`,
      voice && `## Voice Layer\nRegister: ${voice.register}\nCadence: ${voice.cadence}\nLexicon: ${voice.lexicon}`,
    ].filter(Boolean).join("\n\n");

    if (profile === "character-ai") {
      return [
        ["name", "Name", character.name],
        ["description", "Short Description", summarizeCharacter(character)],
        ["greeting", "Greeting", character.speech || `{{user}} encounters ${character.name}. Begin in character, grounded in the current scene.`],
        ["definition", "Definition / Advanced", promptDescription],
        ["examples", "Example Dialogue", character.speech],
      ];
    }
    if (profile === "sillytavern") {
      return [
        ["name", "Name", character.name],
        ["description", "Description", fullDescription],
        ["personality", "Personality", character.personality],
        ["scenario", "Scenario", [world?.cosmology, world?.rules, character.goals].filter(Boolean).join("\n\n")],
        ["first_mes", "First Message", character.speech || "{{char}} studies {{user}} for a moment before speaking."],
        ["mes_example", "Example Messages", character.speech],
        ["creator_notes", "Creator Notes", promptDescription],
      ];
    }
    if (profile === "generic") {
      return [
        ["system", "System / Director Brief", promptDescription],
        ["summary", "30-Word Character Summary", summarizeCharacter(character)],
        ["tags", "Tags", tags],
        ["continuity", "Continuity Instruction", `Preserve ${character.name}'s goals, constraints, speech habits, and linked world rules. Do not invent new cosmology unless explicitly authorized by the user.`],
      ];
    }
    return [
      ["name", "Name", character.name],
      ["summary", "Description Summary (<=30 words)", summarizeCharacter(character)],
      ["fullDescription", "Description", fullDescription],
      ["tags", "Tags", tags],
      ["promptDescription", "Prompt Description (AI)", promptDescription],
      ["speech", "Example Dialogues", character.speech],
    ];
  };

  const buildStorylineDeploy = (story: StorylineRecord): DeployBlock[] => {
    const world = worlds.find((item) => item.id === story.worldId) || null;
    const cast = chars.filter((character) => story.characterIds.includes(character.id));
    return [
      ["name", "Storyline Name", story.name],
      ["summary", "Storyline Summary", compactWords(story.premise || story.openingScene, 40)],
      ["opening", "Opening Scene", story.openingScene],
      ["premise", "Premise", story.premise],
      ["cast", "Linked Cast", cast.map((character) => `${character.name}: ${compactWords(character.role || character.personality, 24)}`).join("\n")],
      ["rules", "Branching / Continuity Rules", [buildWorldContext(world), story.branchingRules, story.continuityState, story.endingConditions].filter(Boolean).join("\n\n")],
      ["beats", "Major Beats", story.beats],
    ];
  };

  const deployBlocks = current && tab === "characters"
    ? buildCharacterDeploy(deployProfile, current as CharacterRecord)
    : current && tab === "storylines"
      ? buildStorylineDeploy(current as StorylineRecord)
      : [];
  const markerText = deployBlocks.map(([, , value]) => value).join("\n\n");
  const markerHasUser = markerText.includes("{{user}}");
  const pronounHits = (markerText.match(/\b(you|your|yours|yourself)\b/gi) || []).length;
  const storagePct = Math.min(100, Math.round((storageBytes / FIVE_MB) * 100));
  const storageTone = storagePct >= 90 ? "text-rose-400" : storagePct >= 70 ? "text-amber-400" : "text-zinc-500";

  const generateParsePrompt = () => {
    if (!current || !parseInput.trim()) return;
    const fieldList = FIELDS[tab].map(([key, label]) => `  "${key}": "${label}"`).join(",\n");
    const prompt = `Parse the following free-form concept into structured fields for a ${tabMeta.singular} record in my worldbuilding forge. Return ONLY valid JSON. Do not fabricate unsupported facts.\n\nTarget record: ${tabMeta.singular} "${current.name}"\n\nFields to fill:\n{\n${fieldList}\n}\n\nConcept text:\n"""\n${parseInput}\n"""`;
    copy(prompt, "parsePrompt");
    setParseMsg("Prompt copied. Paste it into your model of choice, then paste the JSON response below and preview the diff before applying.");
  };

  const previewParse = () => {
    if (!current || !parseOutput.trim()) return;
    try {
      const match = parseOutput.match(/```json\s*([\s\S]*?)```/) || parseOutput.match(/\{[\s\S]*\}/);
      const jsonStr = match ? (match[1] || match[0]) : parseOutput;
      const parsed = JSON.parse(jsonStr.trim());
      const allowed = new Set(FIELDS[tab].map(([key]) => key));
      const draft: Record<string, string> = {};
      Object.entries(parsed).forEach(([key, value]) => {
        if (allowed.has(key) && typeof value === "string" && value.trim()) draft[key] = value.trim();
      });
      setParseDraft(draft);
      setParseSelected(Object.fromEntries(Object.keys(draft).map((key) => [key, true])));
      setParseMsg(Object.keys(draft).length ? `Preview ready: ${Object.keys(draft).length} field(s) detected.` : "Valid JSON, but no supported fields were found.");
    } catch (error) {
      setParseMsg(`Parse error: ${error instanceof Error ? error.message : "invalid JSON"}. Ask the model to return valid JSON only.`);
    }
  };

  const applyParse = () => {
    if (!current || !parseDraft) return;
    const updated = { ...(current as Record<string, unknown>), updatedAt: nowIso() } as AnyRecord & Record<string, unknown>;
    let applied = 0;
    Object.entries(parseDraft).forEach(([key, value]) => {
      if (!parseSelected[key]) return;
      updated[key] = parseApplyMode === "replace" || !updated[key] ? value : `${updated[key]}\n\n${value}`;
      applied++;
    });
    setItemsFor(tab, (prev) => prev.map((item) => (item.id === current.id ? updated : item)));
    setParseMsg(`Applied ${applied} field${applied === 1 ? "" : "s"} by ${parseApplyMode}.`);
    setParseInput("");
    setParseOutput("");
    setParseDraft(null);
    setParseSelected({});
    window.setTimeout(() => {
      setShowParse(false);
      setParseMsg("");
    }, 1000);
  };

  const addPlatform = () => setPlatforms((prev) => [...prev, { id: uid(), name: "New Platform", tos: "", promos: "", readme: "", notes: "" }]);
  const updatePlatform = (id: string, key: keyof PlatformLink, value: string) => setPlatforms((prev) => prev.map((p) => (p.id === id ? { ...p, [key]: value } : p)));
  const deletePlatform = (id: string) => setPlatforms((prev) => prev.filter((p) => p.id !== id));
  const ratingColor = (rating: Rating) => rating === "nsfw" ? "text-rose-400 border-rose-900" : "text-emerald-400 border-emerald-900";
  const ratingDot = (rating: Rating) => rating === "nsfw" ? "bg-rose-500" : "bg-emerald-500";

  const renderDeploy = () => (
    <div className="p-6 max-w-4xl">
      <div className="flex items-center justify-between mb-2">
        <div>
          <div className="text-xs text-zinc-500 uppercase tracking-wider">Deploy - tap to copy</div>
          <div className="text-xs text-zinc-600 mt-1">Manual transfer cockpit. No external platform integration is attempted.</div>
        </div>
        <button onClick={() => setDeployView(false)} className="flex items-center gap-1 px-3 py-1 border border-zinc-800 hover:border-emerald-600 text-xs"><Edit3 size={12} /> edit</button>
      </div>

      {tab === "characters" && (
        <div className="mb-4 flex flex-wrap items-center gap-2">
          <select value={deployProfile} onChange={(event) => setDeployProfile(event.target.value)} className="bg-zinc-900 border border-zinc-800 p-2 text-xs focus:outline-none focus:border-emerald-600">
            {DEPLOY_PROFILES.map((profile) => <option key={profile.key} value={profile.key}>{profile.name}</option>)}
          </select>
          <div className="text-xs text-zinc-500">{DEPLOY_PROFILES.find((profile) => profile.key === deployProfile)?.note}</div>
        </div>
      )}

      <div className={`mb-4 p-3 border text-xs ${markerHasUser ? "border-emerald-900 bg-emerald-950/20 text-emerald-300" : pronounHits ? "border-amber-900 bg-amber-950/20 text-amber-300" : "border-zinc-800 bg-zinc-900/30 text-zinc-500"}`}>
        <Shield size={12} className="inline mr-1" />
        {markerHasUser ? "{{user}} present" : pronounHits ? "Possible {{user}} pass needed" : "No obvious {{user}} requirement"}
        {!markerHasUser && pronounHits > 0 && ` - detected ${pronounHits} second-person pronoun(s). Review manually.`}
        <button onClick={() => copy("{{user}}", "user-marker")} className="ml-3 underline decoration-dotted hover:text-emerald-200">copy marker</button>
      </div>

      {deployBlocks.map(([key, label, value]) => {
        if (!value) return null;
        const wc = label.toLowerCase().includes("summary") ? wordCount(value) : null;
        return (
          <div key={key} onClick={() => copy(value, key)} className="mb-3 p-3 bg-zinc-900 border border-zinc-800 hover:border-emerald-700 cursor-pointer group">
            <div className="flex items-center justify-between mb-1">
              <div className="text-xs text-emerald-500 uppercase tracking-wider">{label}{wc !== null && ` - ${wc} words`}</div>
              {copied === key ? <Check size={12} className="text-emerald-400" /> : <Copy size={12} className="text-zinc-600 group-hover:text-emerald-500" />}
            </div>
            <div className="text-xs text-zinc-300 whitespace-pre-wrap font-mono">{value}</div>
          </div>
        );
      })}

      {(current?.flags.length ?? 0) > 0 && (
        <div className="mt-4 p-3 border border-amber-900/50 bg-amber-950/20 text-xs text-amber-300">
          <AlertTriangle size={12} className="inline mr-1" /> Self-tagged flags: {current?.flags.join(", ")} - verify against target platform policy before public submission.
        </div>
      )}
    </div>
  );

  const renderEditor = () => (
    <div className="p-6 max-w-4xl">
      <div className="flex flex-wrap gap-2 mb-4">
        <input value={current?.name || ""} onChange={(event) => update("name", event.target.value)} className={`flex-1 min-w-[240px] bg-transparent border-b text-xl focus:outline-none pb-1 ${current ? ratingColor(current.rating) : ""}`} />
        {(tab === "characters" || tab === "storylines") && <button onClick={() => setDeployView(true)} className="px-3 py-1 border border-emerald-800 hover:border-emerald-500 text-emerald-400 text-xs flex items-center gap-1"><Eye size={12} />deploy</button>}
        <button onClick={() => setShowParse(true)} className="px-3 py-1 border border-cyan-800 hover:border-cyan-500 text-cyan-400 text-xs flex items-center gap-1">parse</button>
        {tab === "worlds" && <button onClick={exportDirectorPrompt} className="px-3 py-1 border border-amber-800 hover:border-amber-500 text-amber-400 text-xs flex items-center gap-1"><Download size={12} />director</button>}
        <button onClick={exportSessionBrief} className="px-3 py-1 border border-purple-800 hover:border-purple-500 text-purple-300 text-xs flex items-center gap-1"><Download size={12} />session</button>
        <button onClick={exportMD} className="px-3 py-1 border border-zinc-800 hover:border-emerald-600 text-xs flex items-center gap-1"><Download size={12} />md</button>
        <button onClick={exportJSON} className="px-3 py-1 border border-zinc-800 hover:border-emerald-600 text-xs flex items-center gap-1"><Download size={12} />json</button>
        {tab === "voice" && <button onClick={() => setShowTips(true)} className="px-3 py-1 border border-emerald-800 hover:border-emerald-500 text-emerald-400 text-xs flex items-center gap-1"><BookOpen size={12} />tips</button>}
      </div>

      <div className="mb-4 p-3 border border-zinc-800 bg-zinc-900/30">
        <div className="flex items-center gap-3 mb-2">
          <Shield size={12} className="text-zinc-500" />
          <span className="text-xs text-zinc-500 uppercase tracking-wider">content rating</span>
          <div className="flex gap-1">
            {(["sfw", "nsfw"] as Rating[]).map((rating) => (
              <button key={rating} onClick={() => update("rating", rating)} className={`px-2 py-0.5 text-xs uppercase ${current?.rating === rating ? (rating === "nsfw" ? "bg-rose-900/40 text-rose-300 border border-rose-700" : "bg-emerald-900/40 text-emerald-300 border border-emerald-700") : "text-zinc-600 border border-zinc-800"}`}>{rating}</button>
            ))}
          </div>
        </div>
        <div className="flex flex-wrap gap-1">
          {FLAGS.map((flag) => (
            <button key={flag} onClick={() => toggleFlag(flag)} className={`px-2 py-0.5 text-xs ${current?.flags.includes(flag) ? "bg-amber-900/40 text-amber-300 border border-amber-700" : "text-zinc-600 border border-zinc-800 hover:border-zinc-600"}`}>{flag}</button>
          ))}
        </div>
        <div className="mt-2 text-xs text-zinc-600 italic">Self-tagged, not a moderation oracle. Verify against target platform policy.</div>
      </div>

      {tab === "characters" && current && (
        <div className="mb-4">
          <label className="text-xs text-zinc-500 flex items-center gap-1"><Link2 size={12} /> linked world</label>
          <select value={(current as CharacterRecord).worldId} onChange={(event) => update("worldId", event.target.value)} className="w-full bg-zinc-900 border border-zinc-800 p-2 mt-1 focus:outline-none focus:border-emerald-600">
            <option value="">- none -</option>
            {worlds.map((world) => <option key={world.id} value={world.id}>{world.name}</option>)}
          </select>
          {linkedWorld && <div className="mt-2 p-3 bg-zinc-900/50 border-l-2 border-emerald-700 text-xs text-zinc-400 whitespace-pre-wrap">{linkedWorld.cosmology || "(no cosmology set)"}{linkedWorld.tone && `\n\nTone: ${linkedWorld.tone}`}</div>}
        </div>
      )}

      {tab === "voice" && current && (
        <div className="mb-4">
          <label className="text-xs text-zinc-500 flex items-center gap-1"><Link2 size={12} /> linked character</label>
          <select value={(current as VoiceRecord).characterId} onChange={(event) => update("characterId", event.target.value)} className="w-full bg-zinc-900 border border-zinc-800 p-2 mt-1 focus:outline-none focus:border-emerald-600">
            <option value="">- none -</option>
            {chars.map((character) => <option key={character.id} value={character.id}>{character.name}</option>)}
          </select>
          {linkedChar && <div className="mt-2 p-3 bg-zinc-900/50 border-l-2 border-emerald-700 text-xs text-zinc-400 whitespace-pre-wrap">{linkedChar.speech || linkedChar.personality || "(no speech/personality set)"}</div>}
        </div>
      )}

      {tab === "storylines" && current && (
        <div className="mb-4 space-y-3">
          <div>
            <label className="text-xs text-zinc-500 flex items-center gap-1"><Link2 size={12} /> linked world</label>
            <select value={(current as StorylineRecord).worldId} onChange={(event) => update("worldId", event.target.value)} className="w-full bg-zinc-900 border border-zinc-800 p-2 mt-1 focus:outline-none focus:border-emerald-600">
              <option value="">- none -</option>
              {worlds.map((world) => <option key={world.id} value={world.id}>{world.name}</option>)}
            </select>
          </div>
          <div className="p-3 border border-zinc-800 bg-zinc-900/30">
            <div className="text-xs text-zinc-500 uppercase tracking-wider mb-2">linked cast</div>
            <div className="grid md:grid-cols-2 gap-1">
              {chars.map((character) => {
                const checked = (current as StorylineRecord).characterIds.includes(character.id);
                const nextIds = checked ? (current as StorylineRecord).characterIds.filter((id) => id !== character.id) : [...(current as StorylineRecord).characterIds, character.id];
                return <button key={character.id} onClick={() => update("characterIds", nextIds)} className={`text-left px-2 py-1 border text-xs ${checked ? "border-emerald-700 text-emerald-300 bg-emerald-950/20" : "border-zinc-800 text-zinc-500 hover:border-zinc-600"}`}>{character.name}</button>;
              })}
            </div>
          </div>
        </div>
      )}

      {tab === "worlds" && current && (worldCharacters.length > 0 || worldStorylines.length > 0) && (
        <div className="mb-4 grid md:grid-cols-2 gap-3">
          <div className="p-3 border border-zinc-800 bg-zinc-900/30">
            <div className="text-xs text-zinc-500 uppercase tracking-wider mb-2">characters in this world</div>
            {worldCharacters.map((character) => <button key={character.id} onClick={() => { setTab("characters"); setSel({ ...sel, characters: character.id }); }} className="block w-full text-left px-2 py-1 mb-1 border border-zinc-800 hover:border-emerald-700 text-xs text-zinc-300">{character.name}</button>)}
          </div>
          <div className="p-3 border border-zinc-800 bg-zinc-900/30">
            <div className="text-xs text-zinc-500 uppercase tracking-wider mb-2">storylines in this world</div>
            {worldStorylines.map((story) => <button key={story.id} onClick={() => { setTab("storylines"); setSel({ ...sel, storylines: story.id }); }} className="block w-full text-left px-2 py-1 mb-1 border border-zinc-800 hover:border-emerald-700 text-xs text-zinc-300">{story.name}</button>)}
          </div>
        </div>
      )}

      {FIELDS[tab].map(([key, label]) => (
        <div key={key} className="mb-4">
          <label className="text-xs text-zinc-500 uppercase tracking-wider">{label}</label>
          <textarea value={current ? String((current as Record<string, unknown>)[key] || "") : ""} onChange={(event) => update(key, event.target.value)} rows={4} className="w-full bg-zinc-900 border border-zinc-800 p-2 mt-1 focus:outline-none focus:border-emerald-600 resize-y text-xs" />
        </div>
      ))}
    </div>
  );

  return (
    <div className="flex h-screen bg-zinc-950 text-zinc-100 font-mono text-sm">
      <div className="w-72 border-r border-zinc-800 flex flex-col">
        <div className="p-3 border-b border-zinc-800">
          <div className="text-emerald-400 uppercase tracking-wider text-xs">World / Character Forge</div>
          <div className="text-zinc-600 text-xs mt-1">memory layer for bots that forget context</div>
        </div>

        <div className="grid grid-cols-4 border-b border-zinc-800">
          {TABS.map((t) => {
            const Icon = t.icon;
            return (
              <button key={t.key} title={t.label} onClick={() => { setTab(t.key); setDeployView(false); }} className={`p-3 flex justify-center ${tab === t.key ? "bg-zinc-800 text-emerald-400" : "text-zinc-500 hover:text-zinc-300"}`}>
                <Icon size={16} />
              </button>
            );
          })}
        </div>

        <div className="p-2 border-b border-zinc-800 flex gap-1">
          {(["all", "sfw", "nsfw"] as FilterMode[]).map((filterMode) => (
            <button key={filterMode} onClick={() => setMode(filterMode)} className={`flex-1 px-2 py-1 text-xs uppercase ${mode === filterMode ? (filterMode === "nsfw" ? "bg-rose-900/40 text-rose-300" : filterMode === "sfw" ? "bg-emerald-900/40 text-emerald-300" : "bg-zinc-800 text-zinc-200") : "text-zinc-600 hover:text-zinc-400"}`}>{filterMode}</button>
          ))}
        </div>

        <div className="p-2 border-b border-zinc-800 space-y-2">
          <div className="flex items-center gap-2 bg-zinc-900 border border-zinc-800 px-2 py-1">
            <Search size={12} className="text-zinc-600" />
            <input value={query} onChange={(event) => setQuery(event.target.value)} placeholder={`search ${tabMeta.label.toLowerCase()}`} className="w-full bg-transparent focus:outline-none text-xs text-zinc-300" />
          </div>
          <div className="grid grid-cols-3 gap-1">
            <button onClick={add} className="flex items-center justify-center gap-1 p-2 bg-emerald-900/30 hover:bg-emerald-900/50 text-emerald-400 rounded text-xs"><Plus size={12} /> new</button>
            <button onClick={() => importRef.current?.click()} className="flex items-center justify-center gap-1 p-2 border border-zinc-800 hover:border-cyan-700 text-cyan-400 rounded text-xs"><Upload size={12} /> load</button>
            <button onClick={exportBundle} className="flex items-center justify-center gap-1 p-2 border border-zinc-800 hover:border-emerald-700 text-zinc-300 rounded text-xs"><Download size={12} /> all</button>
          </div>
          <input ref={importRef} type="file" accept="application/json,.json" className="hidden" onChange={(event) => handleImport(event.target.files?.[0])} />
        </div>

        <div className="flex-1 overflow-y-auto">
          {visible.map((item) => (
            <div key={item.id} onClick={() => setSel({ ...sel, [tab]: item.id })} className={`group flex items-center gap-2 p-2 border-b border-zinc-900 cursor-pointer ${sel[tab] === item.id ? "bg-zinc-800" : "hover:bg-zinc-900"}`}>
              <span className={`w-1.5 h-1.5 rounded-full ${ratingDot(item.rating)}`} />
              <span className="flex-1 truncate">{item.name}</span>
              <button title="Soft delete" onClick={(event) => { event.stopPropagation(); softDelete(item.id); }} className="opacity-0 group-hover:opacity-100 text-red-400"><Trash2 size={12} /></button>
            </div>
          ))}
          {!visible.length && <div className="p-4 text-zinc-600 text-xs">empty or filtered</div>}
        </div>

        <div className="border-t border-zinc-800 p-2 space-y-1">
          <div className="flex items-center justify-between text-xs text-zinc-600 px-1">
            <span className="flex items-center gap-1"><Save size={12} /> {saveState}{lastSaved && saveState === "saved" ? ` ${lastSaved}` : ""}</span>
            <span className={storageTone}><Database size={12} className="inline mr-1" />{storagePct}%</span>
          </div>
          <button onClick={() => setShowTrash(true)} className="w-full flex items-center gap-2 p-2 text-zinc-500 hover:text-rose-400 text-xs">
            <RotateCcw size={12} /> trash / restore ({deleted.length})
          </button>
          <button onClick={() => setShowPlatforms(true)} className="w-full flex items-center gap-2 p-2 text-zinc-500 hover:text-emerald-400 text-xs">
            <LinkIcon size={12} /> platform links
          </button>
        </div>
      </div>

      <div className="flex-1 overflow-y-auto">
        {!current ? (
          <div className="h-full flex items-center justify-center text-zinc-600">select or create a {tabMeta.singular}</div>
        ) : deployView && (tab === "characters" || tab === "storylines") ? renderDeploy() : renderEditor()}
      </div>

      {showTips && (
        <Modal tone="emerald" title="Audacity Quick Tips" onClose={() => setShowTips(false)} icon={<BookOpen size={14} />}>
          <div className="p-4 space-y-3">
            {TIPS.map((tip) => (
              <div key={tip.h} className="border-l-2 border-emerald-800 pl-3">
                <div className="text-emerald-400 text-xs uppercase tracking-wider mb-1">{tip.h}</div>
                <div className="text-zinc-300 text-xs leading-relaxed">{tip.b}</div>
              </div>
            ))}
          </div>
        </Modal>
      )}

      {showTrash && (
        <Modal tone="rose" title="Trash / Restore" onClose={() => setShowTrash(false)} icon={<RotateCcw size={14} />}>
          <div className="p-4 space-y-2">
            <div className="text-xs text-zinc-500 italic border-l-2 border-amber-800 pl-3 mb-3">Soft delete is recoverable. Permanent purge is not.</div>
            {deleted.map((entry) => (
              <div key={entry.tombstoneId} className="border border-zinc-800 p-3 flex items-center gap-3">
                <div className="flex-1">
                  <div className="text-zinc-200 text-sm">{entry.record.name}</div>
                  <div className="text-zinc-600 text-xs">{entry.collection} - deleted {new Date(entry.deletedAt).toLocaleString()}</div>
                </div>
                <button onClick={() => restoreDeleted(entry.tombstoneId)} className="px-2 py-1 text-xs border border-emerald-800 text-emerald-400 hover:border-emerald-500">restore</button>
                <button onClick={() => purgeDeleted(entry.tombstoneId)} className="px-2 py-1 text-xs border border-rose-900 text-rose-400 hover:border-rose-600">purge</button>
              </div>
            ))}
            {!deleted.length && <div className="text-center text-zinc-600 text-xs py-6">trash empty</div>}
          </div>
        </Modal>
      )}

      {showPlatforms && (
        <Modal tone="emerald" title="Platform Links" onClose={() => setShowPlatforms(false)} icon={<LinkIcon size={14} />} extra={<button onClick={addPlatform} className="text-emerald-400 hover:text-emerald-300"><Plus size={14} /></button>}>
          <div className="p-4 space-y-4">
            <div className="text-xs text-zinc-500 italic border-l-2 border-amber-800 pl-3">The forge cannot monitor external sites. Paste ToS, promo, and readme URLs here and open them manually.</div>
            {platforms.map((platform) => (
              <div key={platform.id} className="border border-zinc-800 p-3 space-y-2">
                <div className="flex gap-2">
                  <input value={platform.name} onChange={(event) => updatePlatform(platform.id, "name", event.target.value)} className="flex-1 bg-transparent border-b border-zinc-800 text-emerald-400 text-sm focus:outline-none focus:border-emerald-600 pb-1" />
                  <button onClick={() => deletePlatform(platform.id)} className="text-red-500 hover:text-red-400"><Trash2 size={12} /></button>
                </div>
                {(["tos", "promos", "readme"] as const).map((key) => (
                  <div key={key} className="flex gap-2 items-center">
                    <input value={platform[key]} onChange={(event) => updatePlatform(platform.id, key, event.target.value)} placeholder={key === "tos" ? "Terms of Service" : key === "promos" ? "Promotions / Programs" : "Readme / Docs"} className="flex-1 bg-zinc-900 border border-zinc-800 p-1.5 text-xs focus:outline-none focus:border-emerald-600" />
                    {platform[key] && <a href={platform[key]} target="_blank" rel="noopener noreferrer" className="text-emerald-500 hover:text-emerald-300 text-xs">open</a>}
                  </div>
                ))}
                <textarea value={platform.notes} onChange={(event) => updatePlatform(platform.id, "notes", event.target.value)} placeholder="Notes: last checked date, limits, etc." rows={2} className="w-full bg-zinc-900 border border-zinc-800 p-1.5 text-xs focus:outline-none focus:border-emerald-600 resize-y" />
              </div>
            ))}
          </div>
        </Modal>
      )}

      {showParse && (
        <Modal tone="cyan" title={`Paste & Parse with Diff - ${tabMeta.singular}`} onClose={() => { setShowParse(false); setParseMsg(""); }} icon={null}>
          <div className="p-4 space-y-4">
            <div className="text-xs text-zinc-500 italic border-l-2 border-cyan-800 pl-3">Free-form text goes in, structured fields come out, but nothing touches the record until you preview and approve the diff.</div>

            <div>
              <label className="text-xs text-cyan-500 uppercase tracking-wider">1. your concept</label>
              <textarea value={parseInput} onChange={(event) => setParseInput(event.target.value)} rows={5} placeholder="Paste concept notes..." className="w-full bg-zinc-900 border border-zinc-800 p-2 mt-1 focus:outline-none focus:border-cyan-600 resize-y text-xs" />
              <button onClick={generateParsePrompt} disabled={!parseInput.trim()} className="mt-2 px-3 py-1 border border-cyan-800 hover:border-cyan-500 text-cyan-400 text-xs disabled:opacity-30 disabled:cursor-not-allowed">copy parse prompt</button>
            </div>

            <div>
              <label className="text-xs text-cyan-500 uppercase tracking-wider">2. paste JSON response</label>
              <textarea value={parseOutput} onChange={(event) => setParseOutput(event.target.value)} rows={6} placeholder={'{\n  "cosmology": "...",\n  "rules": "..."\n}'} className="w-full bg-zinc-900 border border-zinc-800 p-2 mt-1 focus:outline-none focus:border-cyan-600 resize-y text-xs font-mono" />
              <div className="flex flex-wrap items-center gap-2 mt-2">
                <button onClick={previewParse} disabled={!parseOutput.trim()} className="px-3 py-1 border border-cyan-800 hover:border-cyan-500 text-cyan-400 text-xs disabled:opacity-30 disabled:cursor-not-allowed">preview diff</button>
                <select value={parseApplyMode} onChange={(event) => setParseApplyMode(event.target.value as "append" | "replace")} className="bg-zinc-900 border border-zinc-800 p-1 text-xs focus:outline-none focus:border-cyan-600">
                  <option value="append">append selected fields</option>
                  <option value="replace">replace selected fields</option>
                </select>
                <button onClick={applyParse} disabled={!parseDraft} className="px-3 py-1 border border-emerald-800 hover:border-emerald-500 text-emerald-400 text-xs disabled:opacity-30 disabled:cursor-not-allowed">apply selected</button>
              </div>
            </div>

            {parseDraft && (
              <div className="space-y-3">
                {Object.entries(parseDraft).map(([key, incoming]) => {
                  const label = FIELDS[tab].find(([fieldKey]) => fieldKey === key)?.[1] || key;
                  const existing = current ? String((current as Record<string, unknown>)[key] || "") : "";
                  return (
                    <div key={key} className="border border-zinc-800 bg-zinc-900/30 p-3">
                      <label className="flex items-center gap-2 text-xs text-cyan-400 uppercase tracking-wider mb-2">
                        <input type="checkbox" checked={!!parseSelected[key]} onChange={(event) => setParseSelected({ ...parseSelected, [key]: event.target.checked })} /> {label}
                      </label>
                      <div className="grid md:grid-cols-2 gap-3">
                        <div>
                          <div className="text-xs text-zinc-600 mb-1">existing</div>
                          <div className="text-xs text-zinc-400 whitespace-pre-wrap border border-zinc-800 p-2 min-h-24">{existing || "(empty)"}</div>
                        </div>
                        <div>
                          <div className="text-xs text-cyan-600 mb-1">incoming</div>
                          <div className="text-xs text-zinc-300 whitespace-pre-wrap border border-cyan-900/60 p-2 min-h-24">{incoming}</div>
                        </div>
                      </div>
                    </div>
                  );
                })}
              </div>
            )}

            {parseMsg && <div className="text-xs text-cyan-300 p-2 bg-cyan-950/30 border border-cyan-900">{parseMsg}</div>}
          </div>
        </Modal>
      )}
    </div>
  );
}

function Modal({
  children,
  extra,
  icon,
  onClose,
  title,
  tone,
}: {
  children: React.ReactNode;
  extra?: React.ReactNode;
  icon: React.ReactNode;
  onClose: () => void;
  title: string;
  tone: "cyan" | "emerald" | "rose";
}) {
  const border = tone === "rose" ? "border-rose-900" : tone === "cyan" ? "border-cyan-900" : "border-emerald-900";
  const text = tone === "rose" ? "text-rose-300" : tone === "cyan" ? "text-cyan-400" : "text-emerald-400";
  return (
    <div onClick={onClose} className="fixed inset-0 bg-black/80 flex items-center justify-center p-4 z-50">
      <div onClick={(event) => event.stopPropagation()} className={`bg-zinc-950 border ${border} max-w-4xl w-full max-h-[88vh] overflow-y-auto`}>
        <div className={`sticky top-0 bg-zinc-950 border-b ${border} p-4 flex items-center justify-between`}>
          <div className={`flex items-center gap-2 ${text}`}><span>{icon}</span><span className="uppercase tracking-wider text-xs">{title}</span></div>
          <div className="flex gap-2">
            {extra}
            <button onClick={onClose} className="text-zinc-500 hover:text-zinc-200"><X size={14} /></button>
          </div>
        </div>
        {children}
      </div>
    </div>
  );
}
