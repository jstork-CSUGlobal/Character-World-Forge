      background: rgba(255, 255, 255, .08);
      overflow: hidden;
      border: 1px solid rgba(255, 255, 255, .08);
    }
    .meter > span { display: block; height: 100%; background: var(--ok); }
    .meter.warn > span { background: var(--warn); }
    .meter.danger > span { background: var(--danger); }
