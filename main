    .brand small, .muted { color: var(--muted); }
    .tabs, .row, .actions, .filters { display: flex; gap: .5rem; align-items: center; flex-wrap: wrap; }
    .tabs button { flex: 1; padding: .55rem .4rem; }
    .tabs button.active { border-color: var(--brand); color: #bae6fd; background: rgba(56, 189, 248, .12); }
